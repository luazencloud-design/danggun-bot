{
  "manifest_version": 3,
  "name": "당근 자동응답 봇",
  "version": "0.4.0",
  "description": "당근마켓 채팅을 Gemini AI가 자동으로 응답. 위험 키워드 감지시 사람 확인 모드로 전환.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "당근 자동응답 봇"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.daangn.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://chat.daangn.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ]
}
